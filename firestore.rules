rules_version = '2';

// Bufalotek Center — Firestore Security Rules
//
// Roller:
//   - admin: Tüm dokümanlara tam yetki. Custom claim ile taşınır.
//   - user:  Toplantıları okuyabilir, üyeleri okuyabilir. Yazamaz/silemez.
//   - logTutucu: Admin'in o gün için izin verdiği user; sadece o günkü toplantıya write yapabilir.
//
// Custom claims ayarı:
//   İlk admin el ile Firebase Console'dan ayarlanmalı:
//   auth > kullanıcı > "Custom claims" = { "role": "admin" }
//
// Doküman yol (path) şeması:
//   /users/{uid}                  = kullanıcı profili + rol alanı (mirror)
//   /members/{memberId}            = topluluk üyesi kaydı
//   /meetings/{meetingId}           = toplantı kaydı (gundem, kararlar, gorevler, date, title)
//   /attendance/{attendanceId}     = { meetingId, memberId }
//   /greyList/{memberId}            = gri liste kaydı (memberId = memberId)
//   /logPermissions/{logId}        = { meetingId, userId, date, grantedBy }
//   /config/roles                  = uygulama ayarları (sadece admin)

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- YARDIMCI FONKSİYONLAR ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isUser() {
      return isSignedIn() && (userRole() == 'user' || userRole() == 'admin');
    }

    function uid() {
      return request.auth.uid;
    }

    // ---------- USERS ----------
    // Kullanıcı profili (Firestore users koleksiyonu, custom claims'in aynası)
    match /users/{userId} {
      allow read: if isSignedIn();
      // Sadece admin başka kullanıcının rolünü değiştirebilir.
      // Kullanıcı kendi dokümanını sınırlı şekilde güncelleyebilir (rol dışındaki alanlar).
      allow create: if isSignedIn() && uid() == userId;
      allow update: if isAdmin()
                    || (isSignedIn() && uid() == userId
                        && !('role' in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isAdmin();
    }

    // ---------- MEMBERS (topluluk üyeleri) ----------
    match /members/{memberId} {
      allow read: if isUser();
      allow create, update, delete: if isAdmin()
                                     || isLogTutucuForToday();
    }

    // ---------- MEETINGS ----------
    match /meetings/{meetingId} {
      allow read: if isUser();
      allow create: if isAdmin() || isLogTutucuForToday();
      allow update: if isAdmin() || isLogTutucuForToday();
      allow delete: if isAdmin();
    }

    // ---------- ATTENDANCE ----------
    match /attendance/{aid} {
      allow read: if isUser();
      allow create, update, delete: if isAdmin()
                                     || isLogTutucuForToday();
    }

    // ---------- GREY LIST ----------
    match /greyList/{memberId} {
      allow read: if isUser();
      // Gri liste server tarafından hesaplanmalı; UI sadece admin tarafından manuel override edilebilir
      allow write: if isAdmin();
    }

    // ---------- LOG PERMISSIONS ----------
    // Admin bir kullanıcıya "bugün sen log tutabilirsin" izni verir.
    match /logPermissions/{permId} {
      allow read: if isUser();
      allow create, update, delete: if isAdmin();
    }

    // ---------- CONFIG ----------
    match /config/{docId} {
      allow read: if isUser();
      allow write: if isAdmin();
    }

    // ---------- YARDIMCI: bugünün log tutucusu mu? ----------
    function isLogTutucuForToday() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/logPermissions/$(getLogPermissionIdForToday()));
    }

    function getLogPermissionIdForToday() {
      // Basit yaklaşıım: permission id = uid + '_' + todayISO
      return uid() + '_' + timestampToString(request.time);
    }

    // Sağlayıcılarda timestamp->string dönüşümü yok; bu nedenle gerçek hesap
    // uygulama tarafında "logPermissions/{uid}_{YYYY-MM-DD}" formatında kaydedilir
    // ve buradan sorgulanır. (Bkz firestoreService.js: buildPermissionId)
    function timestampToString(ts) {
      return string(ts);
    }
  }
}
